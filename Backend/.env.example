# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_ORIGIN=http://localhost:5173

# MongoDB Database Connection String
DB_CONNECTION_STRING=mongodb://localhost:27017/codifyx

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT_NO=6379
REDIS_PASSWORD=your_redis_password_here

# JWT Secret Key (generate a strong random string)
JWT_KEY=your_super_secret_jwt_key_here_generate_strong_random_string

# Groq AI API Key (for AI features)
GROQ_API_KEY=your_groq_api_key_here

# ============================================
# Google OAuth Configuration
# ============================================
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing one
# 3. Enable Google+ API
# 4. Go to Credentials > OAuth 2.0 Client IDs
# 5. Create OAuth Client ID (Web application)
# 6. Add authorized redirect URIs:
#    - Development: http://localhost:3000/authentication/google/callback
#    - Production: https://your-domain.com/authentication/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/authentication/google/callback

# ============================================
# GitHub OAuth Configuration
# ============================================
# 1. Go to https://github.com/settings/developers
# 2. Click "New OAuth App"
# 3. Fill in application details:
#    - Homepage URL: http://localhost:5173 (dev) or your production URL
#    - Authorization callback URL:
#      - Development: http://localhost:3000/authentication/github/callback
#      - Production: https://your-domain.com/authentication/github/callback
# 4. Register the application and copy Client ID and Secret
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITHUB_REDIRECT_URI=http://localhost:3000/authentication/github/callback

# ============================================
# Cloudinary (for image/video uploads)
# ============================================
# Get these from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Email Configuration (Resend - Recommended)
# ============================================
# Get API key from https://resend.com
RESEND_API_KEY=your_resend_api_key_here
